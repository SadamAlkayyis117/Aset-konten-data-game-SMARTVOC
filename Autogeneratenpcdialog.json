            "annoyed": [
              "Make it quick then!",
              "Don't joke about duty!"
            ]
          }
        },
        {
          "npc_lines": [
            { "text": "Here... these last ten lampposts need 'Don't Litter' posters.", "emotion": "relieved" },
            { "text": "Use the wheat paste bucket. Smooth out bubbles.", "emotion": "instructing" },
            { "text": "I'll watch from here... pretend I'm supervising.", "emotion": "grateful" }
          ],
          "accept_topics": ["ready", "task", "poster"],
          "accept_keywords": ["ready", "got it", "okay", "yes", "start"],
          "fail_responses": {
            "confused": [
              "Just the posters, okay?",
              "Simple task. You got this?"
            ],
            "annoyed": [
              "Captain's watching! Hurry!",
              "No time for questions!"
            ]
          }
        },
        {
          "npc_lines": [
            { "text": "Thank you... really. I owe you one.", "emotion": "grateful" },
            { "text": "Captain drove by - he thinks YOU'RE the new recruit!", "emotion": "relieved" },
            { "text": "Rest now feels possible. Good citizen award coming your way.", "emotion": "warm" }
          ],
          "accept_topics": ["thank", "done", "finish"],
          "accept_keywords": ["done", "finished", "okay", "thanks"],
          "fail_responses": {
            "confused": [
              "Posters up? All done?",
              "Task complete?"
            ],
            "annoyed": [
              "Are they up yet?",
              "Captain's circling back!"
            ]
          }
        }
      ]
    },

    {
