{
  "npc_encounters": [
    {
      "id": "delivery_start",
      "topic": "delivery",
      "formality_level": 0.3,
      "npc_profile": {
        "roles": ["courier"],
        "personality": ["impatient", "stressed"]
      },
      "turns": [
        {
          "npc_lines": [
            { "text": "Damn... why does this always happen to me?", "emotion": "angry" },
            { "text": "Ugh... not today...", "emotion": "frustrated" }
          ],
          "accept_topics": ["help", "problem", "accident"],
          "accept_keywords": ["help", "okay", "wrong", "problem"],
          "fail_responses": {
            "confused": [
              "Huh?",
              "What are you talking about?",
              "No—wait. Start over. What do you mean?"
            ],
            "annoyed": [
              "Seriously?",
              "That makes no sense.",
              "Look, I don't have time for riddles.",
              "Can you not? I'm already having a day."
            ]
          }
        },
        {
          "npc_lines": [
            { "text": "Yeah, as you can see I got a problem here. Bike chain snapped again!", "emotion": "frustrated" },
            { "text": "Third time this month. These packages are due in 30 minutes!", "emotion": "stressed" }
          ],
          "accept_topics": ["bike", "chain", "fix", "deliver", "packages"],
          "accept_keywords": ["fix", "bike", "help", "deliver", "carry", "packages"],
          "fail_responses": {
            "confused": [
              "Wait, what? Focus here man!",
              "I'm not following. Bike. Broken. Packages late."
            ],
            "annoyed": [
              "Dude I'm dying here and you're talking about WHAT?",
              "Not now. Not the time."
            ]
          }
        },
        {
          "npc_lines": [
            { "text": "Wait... are you serious? You wanna help with the delivery?", "emotion": "surprised" },
            { "text": "You're not trying to take my job are you?", "emotion": "suspicious" }
          ],
          "accept_topics": ["help", "deliver", "packages", "carry"],
          "accept_keywords": ["yes", "sure", "help", "deliver", "okay", "fine"],
          "fail_responses": {
            "confused": [
              "Hold up. Say that again?",
              "You're messing with me right?"
            ],
            "annoyed": [
              "Make up your mind already!",
              "Yes or no? I got deliveries burning!"
            ]
          }
        },
        {
          "npc_lines": [
            { "text": "Ah okay okay! Here, take this task!", "emotion": "relieved" },
            { "text": "You need to deliver ALL these packages to every address on the list.", "emotion": "urgent" },
            { "text": "Start with the red labels - those are priority. Don't lose any!", "emotion": "serious" }
          ],
          "accept_topics": ["ready", "task", "packages", "deliver"],
          "accept_keywords": ["ready", "got it", "okay", "yes", "start"],
          "fail_responses": {
            "confused": [
              "You in or what?",
              "Just say yes or no already!"
            ],
            "annoyed": [
              "Come on man, clock's ticking!",
              "Are we doing this or not?"
            ]
          }
        },
        {
          "npc_lines": [
            { "text": "Okay thank you mate! I'll wait here for your update.", "emotion": "grateful" },
            { "text": "Scan the QR code on each package when delivered. I'll track it live.", "emotion": "hopeful" },
            { "text": "Don't let me down - tips are good if you're fast!", "emotion": "motivating" }
          ],
          "accept_topics": ["thank", "done", "update"],
          "accept_keywords": ["okay", "got it", "thanks", "start", "going"],
          "fail_responses": {
            "confused": [
              "Just go already!",
              "You understand right?"
            ],
            "annoyed": [
              "Fine whatever, just GO!",
              "Time's wasting!"
            ]
          }
        }
      ]
    },

    {
      "id": "police_poster",
      "topic": "poster",
      "formality_level": 0.6,
      "npc_profile": {
